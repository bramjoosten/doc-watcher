{
  "name": "doc-watcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mirror a Confluence Server tree to local markdown for search and AI tooling.",
  "bin": {
    "doc-watcher": "src/cli.ts"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "p-limit": "^6.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "smol-toml": "^1.3.1",
    "turndown": "^7.2.0",
    "@joplin/turndown-plugin-gfm": "^1.0.61",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
