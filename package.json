{
  "name": "doc-watcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mirror a Confluence Server tree to local markdown for search and AI tooling.",
  "scripts": {
    "start": "tsx --env-file-if-exists=.env src/taskmanager.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
